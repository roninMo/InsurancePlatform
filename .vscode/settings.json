{
  "cSpell.words": [
    "Addit",
    "chashu",
    "Chbx",
    "Chckbx",
    "Clrs",
    "Demandjump",
    "devlog",
    "Hashbar",
    "navigations",
    "nori",
    "quicklink",
    "quicklinks",
    "Selectedcontent",
    "slct",
    "slctd",
    "sldr",
    "SSAS",
    "subroot",
    "subtable",
    "Svgs",
    "Textareas",
    "Textastic",
    "VITE"
  ],
  // Tailwind @apply css binds
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "ngClass",
    ".*additionalStyles.*", // Add your custom prop pattern here
    ".*styles.*", 
    ".*Styles.*" // Or another pattern
  ],

  // JsDoc specific styling
  "workbench.colorCustomizations": {
    "editorHoverWidget.background": "#1e222a",
    "editorHoverWidget.border": "#3e4451",
    "editorHoverWidget.statusBarBackground": "#21252b",
    "textBlockCodeBlock.background": "#282c34"
  },

  // Editor specific stuff for the terminal
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
  "terminal.integrated.fontSize": 14,
  "editor.fontLigatures": true,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.letterSpacing": 0.5,
  "terminal.integrated.lineHeight": 1.2,

  // Professional Cursor & Styling
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.gpuAcceleration": "on",

  // Clean up the UI
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.location": "right"
}
